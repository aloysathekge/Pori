# Required. Supabase Postgres, async driver. Match the pooler hostname+port
# from Supabase → Project Settings → Database → Connection string (pooler).
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# Required. Used to verify Supabase JWTs (auth).
SUPABASE_URL=https://xxxx.supabase.co

# Comma-separated list of allowed origins for browser requests.
# Include the Vercel prod URL, any preview URLs you want, and localhost dev.
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# LLM provider credentials (whichever the agent config selects).
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
FIREWORKS_API_KEY=
TAVILY_API_KEY=

# Optional tunables (defaults shown).
LOG_LEVEL=INFO
RATE_LIMIT_RPM=60
MAX_CONCURRENT_RUNS=5

# Account connections (native OAuth — Gmail, etc.). Generate the enc key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTIONS_ENC_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
BACKEND_BASE_URL=http://localhost:8000
APP_BASE_URL=http://localhost:5173

# Object storage. 'local' (default) keeps blobs on this machine's disk under
# STORAGE_DIR — fine for dev/single-node. 's3' uses any S3-compatible store
# (needs boto3: pip install boto3). For Supabase Storage: create a bucket,
# then Project Settings -> Storage -> S3 access keys.
STORAGE_BACKEND=local
# STORAGE_S3_ENDPOINT=https://xxxx.supabase.co/storage/v1/s3
# STORAGE_S3_BUCKET=aloy-files
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_REGION=us-east-1
